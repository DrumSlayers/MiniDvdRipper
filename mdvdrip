#!/usr/bin/env bash
# Launcher: runs MiniDvdRipper from its venv without needing to install it.
set -euo pipefail
HERE="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
PY="$HERE/.venv/bin/python"
[ -x "$PY" ] || PY="$(command -v python3)"
exec env PYTHONPATH="$HERE/src" "$PY" -m minidvdripper "$@"
